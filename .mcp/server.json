{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.chrispulman/reactiveui-mcp-server",
  "title": "ReactiveUI MCP Server",
  "description": "ReactiveUI ecosystem guidance for AI-assisted code generation, review, and package/platform recommendations.",
  "version": "0.4.0",
  "packages": [
    {
      "registryType": "nuget",
      "registryBaseUrl": "https://api.nuget.org/v3/index.json",
      "identifier": "CP.ReactiveUI.Mcp.Server",
      "version": "0.4.0",
      "runtimeHint": "dnx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "DOTNET_SKIP_FIRST_TIME_EXPERIENCE",
          "value": "1",
          "description": "Skip .NET CLI first-time setup experience"
        },
        {
          "name": "DOTNET_NOLOGO",
          "value": "1",
          "description": "Suppress .NET logo and startup messages"
        }
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/ChrisPulman/ReactiveUIMcp.Server",
    "source": "github"
  }
}
